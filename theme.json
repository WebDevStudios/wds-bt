{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"color": "#FFFFFF",
					"name": "Base",
					"slug": "base"
				},
				{
					"color": "#111111",
					"name": "Contrast",
					"slug": "contrast"
				},
				{
					"color": "#3B28CC",
					"name": "Primary",
					"slug": "primary"
				},
				{
					"color": "#2667FF",
					"name": "Secondary",
					"slug": "secondary"
				},
				{
					"color": "#2595E7",
					"name": "Tertiary",
					"slug": "tertiary"
				},
				{
					"color": "color-mix(in srgb, currentColor 20%, transparent)",
					"name": "Accent",
					"slug": "accent"
				}
			]
		},
		"layout": {
			"contentSize": "1160px",
			"wideSize": "1200px"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "1",
					"size": "1rem",
					"slug": "10"
				},
				{
					"name": "2",
					"size": "1.25rem",
					"slug": "20"
				},
				{
					"name": "3",
					"size": "min(1.875rem, 5vw)",
					"slug": "30"
				},
				{
					"name": "4",
					"size": "min(2rem, 6vw)",
					"slug": "40"
				},
				{
					"name": "5",
					"size": "min(3.125rem, 6vw)",
					"slug": "50"
				},
				{
					"name": "6",
					"size": "min(3.75rem, 7vw)",
					"slug": "60"
				},
				{
					"name": "7",
					"size": "min(4.375rem, 8vw)",
					"slug": "70"
				}
			],
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			]
		},
		"typography": {
			"writingMode": true,
			"defaultFontSizes": false,
			"fluid": {
				"maxViewportWidth": "1200px",
				"minFontSize": "0.813rem",
				"minViewportWidth": "600px"
			},
			"fontSizes": [
				{
					"fluid": false,
					"name": "Extra Extra Small",
					"size": "0.875rem",
					"slug": "xxs"
				},
				{
					"fluid": false,
					"name": "Extra Small",
					"size": "1rem",
					"slug": "xs"
				},
				{
					"fluid": false,
					"name": "Small",
					"size": "1.125rem",
					"slug": "s"
				},
				{
					"fluid": false,
					"name": "Medium",
					"size": "1.25rem",
					"slug": "m"
				},
				{
					"fluid": false,
					"name": "Large",
					"size": "1.375rem",
					"slug": "l"
				},
				{
					"fluid": {
						"max": "1.75rem",
						"min": "1.5rem"
					},
					"name": "Extra Large",
					"size": "1.75rem",
					"slug": "xl"
				},
				{
					"fluid": {
						"max": "2.25rem",
						"min": "1.5rem"
					},
					"name": "Extra Extra Large",
					"size": "2.25rem",
					"slug": "xxl"
				},
				{
					"fluid": {
						"max": "3rem",
						"min": "1.75rem"
					},
					"name": "Extra Extra Extra Large",
					"size": "3rem",
					"slug": "xxxl"
				},
				{
					"fluid": {
						"max": "3.75rem",
						"min": "2.25rem"
					},
					"name": "Humongous",
					"size": "3.75rem",
					"slug": "xxxxl"
				}
			],
			"fontFamilies": [
				{
					"name": "Inter",
					"slug": "headline",
					"fontFamily": "Inter, sans-serif",
					"fontFace": [
						{
							"src": [
								"file:./assets/fonts/inter/Inter.woff2"
							],
							"fontWeight": "400 500 700",
							"fontStyle": "normal",
							"fontFamily": "Inter"
						}
					]
				},
				{
					"name": "Oxygen",
					"slug": "body",
					"fontFamily": "Oxygen, sans-serif",
					"fontFace": [
						{
							"src": [
								"file:./assets/fonts/oxygen/oxygen-v15-latin-regular.woff2"
							],
							"fontWeight": "400",
							"fontStyle": "normal",
							"fontFamily": "Oxygen"
						},
						{
							"src": [
								"file:./assets/fonts/oxygen/oxygen-v15-latin-700.woff2"
							],
							"fontWeight": "700",
							"fontStyle": "normal",
							"fontFamily": "Oxygen"
						}
					]
				},
				{
					"name": "Roboto Mono",
					"slug": "mono",
					"fontFamily": "Roboto Mono",
					"fontFace": [
						{
							"src": [
								"file:./assets/fonts/roboto-mono/roboto-mono.woff2"
							],
							"fontWeight": "400 500 700",
							"fontStyle": "normal",
							"fontFamily": "Roboto Mono"
						}
					]
				}
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var:preset|color|base",
			"text": "var:preset|color|contrast"
		},
		"spacing": {
			"blockGap": "var:preset|spacing|30",
			"padding": {
				"left": "var:preset|spacing|30",
				"right": "var:preset|spacing|30"
			}
		},
		"typography": {
			"fontFamily": "var:preset|font-family|body",
			"fontSize": "var:preset|font-size|xs",
			"fontWeight": "400",
			"lineHeight": "clamp(130%, 0.7600rem + 0.9178vw, 150%)"
		},
		"blocks": {
			"core/button": {
				"variations": {
					"outline": {
						"border": {
							"color": "var:preset|color|primary",
							"style": "solid",
							"width": "1px"
						},
						"color": {
							"text": "var:preset|color|primary"
						},
						"spacing": {
							"padding": {
								"bottom": "0.5rem",
								"left": "var:preset|spacing|10",
								"right": "var:preset|spacing|10",
								"top": "0.5rem"
							}
						}
					}
				}
			},
			"core/buttons": {
				"spacing": {
					"blockGap": "var:preset|spacing|30"
				}
			},
			"core/calendar": {
				"color": {
					"background": "var:preset|color|base",
					"text": "var:preset|color|contrast"
				},
				"spacing": {
					"margin": {
						"bottom": "var:preset|spacing|30",
						"top": "var:preset|spacing|30"
					}
				},
				"typography": {
					"fontFamily": "var:preset|font-family|body",
					"fontSize": "var:preset|font-size|m"
				}
			},
			"core/code": {
				"color": {
					"background": "var:preset|color|base",
					"text": "var:preset|color|contrast"
				},
				"spacing": {
					"padding": {
						"bottom": "1.5rem",
						"left": "1.5rem",
						"right": "1.5rem",
						"top": "1.5rem"
					}
				},
				"typography": {
					"fontFamily": "var:preset|font-family|mono)",
					"fontSize": "var:preset|font-size|xs)",
					"lineHeight": "clamp(130%, 0.7600rem + 0.9178vw, 150%)"
				}
			},
			"core/comments": {
				"border": {
					"color": "var:preset|color|accent)",
					"style": "solid",
					"width": "2px 0 0 0"
				}
			},
			"core/comments-title": {
				"typography": {
					"fontSize": "var:preset|font-size|xl)"
				}
			},
			"core/cover": {
				"elements": {
					"heading": {
						"typography": {
							"fontWeight": "600"
						}
					}
				},
				"spacing": {
					"margin": {
						"bottom": "0",
						"top": "0"
					},
					"padding": {
						"bottom": "var:preset|spacing|30)",
						"left": "var:preset|spacing|30)",
						"right": "var:preset|spacing|30)",
						"top": "var:preset|spacing|30)"
					}
				}
			},
			"core/file": {
				"border": {
					"color": "var:preset|color|accent)",
					"style": "solid",
					"width": "0 0 2px 0"
				},
				"color": {
					"text": "var:preset|color|contrast)"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|contrast)"
						},
						"typography": {
							"fontFamily": "var:preset|font-family|body)",
							"fontSize": "var:preset|font-size|xs)"
						}
					}
				},
				"spacing": {
					"padding": {
						"bottom": "1rem",
						"left": "0",
						"right": "0",
						"top": "1rem"
					}
				},
				"typography": {
					"fontFamily": "var:preset|font-family|body)",
					"fontSize": "var:preset|font-size|xs)"
				}
			},
			"core/footnotes": {
				"border": {
					"color": "var:preset|color|accent)",
					"style": "solid",
					"width": "2px 0"
				},
				"color": {
					"text": "var:preset|color|contrast)"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|headline)",
					"fontSize": "0.75rem"
				}
			},
			"core/group": {
				"spacing": {
					"margin": {
						"bottom": "0",
						"top": "0"
					}
				}
			},
			"core/list": {
				"spacing": {
					"padding": {
						"bottom": "var:preset|spacing|20)",
						"left": "0",
						"right": "var:preset|spacing|30)",
						"top": "var:preset|spacing|20)"
					}
				}
			},
			"core/navigation": {
				"spacing": {
					"blockGap": "var:preset|spacing|20)"
				},
				"typography": {
					"fontSize": "var:preset|font-size|xs)"
				}
			},
			"core/paragraph": {
				"spacing": {
					"margin": {
						"top": "var:preset|spacing|30)"
					}
				},
				"typography": {
					"fontSize": "var:preset|font-size|xs)",
					"letterSpacing": "0.002em",
					"lineHeight": "clamp(130%, 0.7600rem + 0.9178vw, 150%)"
				}
			},
			"core/post-navigation-link": {
				"elements": {
					"link": {
						"typography": {
							"fontWeight": "700"
						}
					}
				},
				"typography": {
					"fontFamily": "var:preset|font-family|body)"
				}
			},
			"core/post-template": {
				"spacing": {
					"blockGap": "var:preset|spacing|40);"
				}
			},
			"core/post-terms": {
				"elements": {
					"link": {
						":hover": {
							"color": {
								"background": "var:preset|color|primary)"
							}
						},
						"color": {
							"background": "var:preset|color|primary)",
							"text": "var:preset|color|grey-700)"
						},
						"spacing": {
							"padding": {
								"bottom": "0",
								"left": "0",
								"right": "0.75rem",
								"top": "0"
							}
						},
						"typography": {
							"fontWeight": "600",
							"textDecoration": "none"
						}
					}
				},
				"typography": {
					"fontFamily": "var:preset|font-family|headline)",
					"fontSize": "0.75rem",
					"fontWeight": "400",
					"textTransform": "uppercase"
				}
			},
			"core/post-title": {
				"typography": {
					"fontSize": "var:preset|font-size|xxxl)"
				}
			},
			"core/preformatted": {
				"color": {
					"background": "var:preset|color|primary)",
					"text": "var:preset|color|contrast)"
				},
				"css": "overflow-x: auto;",
				"spacing": {
					"padding": {
						"bottom": "0.75rem",
						"left": "0.75rem",
						"right": "0.75rem",
						"top": "0.75rem"
					}
				},
				"typography": {
					"fontFamily": "var:preset|font-family|mono)",
					"fontSize": "var:preset|font-size|s)"
				}
			},
			"core/pullquote": {
				"border": {
					"color": "var:preset|color|accent)",
					"style": "solid",
					"width": "2px 0"
				},
				"elements": {
					"cite": {
						"typography": {
							"fontFamily": "var:preset|font-family|body)",
							"fontSize": "var:preset|font-size|xs)",
							"fontStyle": "inherit"
						}
					}
				},
				"spacing": {
					"margin": {
						"bottom": "var:preset|spacing|30)",
						"top": "var:preset|spacing|30)"
					},
					"padding": {
						"bottom": "1.5rem",
						"left": "1.5rem",
						"right": "1.5rem",
						"top": "1.5rem"
					}
				},
				"typography": {
					"fontFamily": "var:preset|font-family|headline)",
					"fontSize": "var:preset|font-size|xl)"
				}
			},
			"core/query-title": {
				"typography": {
					"fontSize": "var:preset|font-size|xxl)",
					"fontStyle": "inherit"
				}
			},
			"core/quote": {
				"border": {
					"color": "var:preset|color|accent)",
					"style": "solid",
					"width": "0 0 0 2px"
				},
				"elements": {
					"cite": {
						"typography": {
							"fontFamily": "var:preset|font-family|body)",
							"fontSize": "0.75rem",
							"fontStyle": "inherit"
						}
					}
				},
				"spacing": {
					"margin": {
						"bottom": "var:preset|spacing|30)",
						"top": "var:preset|spacing|30)"
					},
					"padding": {
						"bottom": "0",
						"left": "1.5rem",
						"right": "1.5rem",
						"top": "0"
					}
				},
				"typography": {
					"fontFamily": "var:preset|font-family|body)"
				},
				"variations": {
					"plain": {
						"border": {
							"style": "none"
						},
						"spacing": {
							"padding": {
								"bottom": "0",
								"left": "0",
								"right": "0",
								"top": "0"
							}
						},
						"typography": {
							"fontStyle": "italic"
						}
					}
				}
			},
			"core/search": {
				"elements": {
					"button": {
						"border": {
							"width": "6px"
						},
						"spacing": {
							"padding": {
								"bottom": "0.5rem",
								"left": "1rem",
								"right": "1rem",
								"top": "0.5rem"
							}
						}
					}
				}
			},
			"core/separator": {
				"border": {
					"color": "currentColor",
					"radius": "0",
					"style": "solid",
					"width": "1px 0 0"
				}
			},
			"core/site-title": {
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"typography": {
					"fontSize": "var:preset|font-size|xxl)",
					"fontWeight": "800"
				}
			},
			"core/social-links": {
				"spacing": {
					"blockGap": "0.625rem"
				}
			},
			"core/spacer": {
				"spacing": {
					"margin": {
						"top": "0"
					}
				}
			},
			"core/table": {
				"typography": {
					"fontSize": "var:preset|font-size|xs)"
				}
			},
			"core/template-part": {
				"spacing": {
					"margin": {
						"top": "0"
					}
				}
			}
		},
		"elements": {
			"button": {
				":focus": {
					"outline": {
						"color": "var:preset|color|primary)",
						"width": "4px"
					}
				},
				":hover": {
					"color": {
						"background": "var:preset|color|primary)",
						"text": "var:preset|color|base)"
					}
				},
				":visited": {
					"color": {
						"text": "var:preset|color|base)"
					}
				},
				"border": {
					"color": "transparent",
					"radius": "4px",
					"style": "solid",
					"width": "1px"
				},
				"color": {
					"background": "var:preset|color|primary)",
					"text": "var:preset|color|base)"
				},
				"spacing": {
					"padding": {
						"bottom": "0.5rem",
						"left": "1rem",
						"right": "2.5rem",
						"top": "0.5rem"
					}
				},
				"typography": {
					"fontSize": "var:preset|font-size|xxs)",
					"fontWeight": "400"
				}
			},
			"caption": {
				"spacing": {
					"margin": {
						"bottom": "0",
						"top": "0.625rem"
					}
				},
				"typography": {
					"fontFamily": "var:preset|font-family|body)",
					"fontSize": "var:preset|font-size|xxs)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var:preset|font-size|xxxxl)",
					"letterSpacing": "-0.02em"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var:preset|font-size|xxxl)",
					"letterSpacing": "-0.01em"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var:preset|font-size|xxl)",
					"letterSpacing": "-0.01em"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var:preset|font-size|xl)",
					"letterSpacing": "-0.02em"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var:preset|font-size|xs)"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var:preset|font-size|xxs)"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|headline)",
					"fontWeight": "500",
					"lineHeight": "clamp(120%, 2.75rem + 0.17vw, 130%)"
				}
			},
			"link": {
				":focus": {
					"color": {
						"text": "var:preset|color|accent)"
					}
				},
				":hover": {
					"color": {
						"text": "var:preset|color|accent)"
					}
				},
				":visited": {
					"color": {
						"text": "var:preset|color|primary)"
					}
				},
				"color": {
					"text": "var:preset|color|primary)"
				},
				"typography": {
					"textDecoration": "none"
				}
			}
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		}
	],
	"customTemplates": [
		{
			"name": "page-blank",
			"postTypes": ["page"],
			"title": "Page: Blank"
		},
		{
			"name": "page-no-title",
			"postTypes": ["page"],
			"title": "Page: No Title"
		}
	]
}
